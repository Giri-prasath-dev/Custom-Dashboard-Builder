# Django Secret Key - generate a secure key for production!
SECRET_KEY=your-secret-key-here

# Debug mode - set to False in production
DEBUG=True

# Allowed hosts - comma-separated list of hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Database configuration (SQLite is default - no extra config needed)
# For MySQL, uncomment and fill in:
# DB_NAME=dashboard_builder
# DB_USER=root
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=3306
